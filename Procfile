python manage.py collectstatic --noinput && python manage.py migrate && python -c "import os, django; os.environ.setdefault('DJANGO_SETTINGS_MODULE', 'virtuhire.settings'); django.setup(); from django.contrib.auth import get_user_model; User = get_user_model(); email = os.getenv('DJANGO_SUPERUSER_EMAIL'); pwd = os.getenv('DJANGO_SUPERUSER_PASSWORD'); (User.objects.create_superuser(email=email, password=pwd) if email and pwd and not User.objects.filter(email=email).exists() else None)" && gunicorn virtuhire.wsgi --log-file -